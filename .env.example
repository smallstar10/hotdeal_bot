# Telegram
TELEGRAM_BOT_TOKEN="paste"
TELEGRAM_CHAT_ID="paste"

# Provider
DATA_PROVIDER="algumon_rank"
COUPANG_ACCESS_KEY=""
COUPANG_SECRET_KEY=""
COUPANG_BASE_URL="https://api-gateway.coupang.com"
COUPANG_SEARCH_PATH="/v2/providers/affiliate_open_api/apis/openapi/v1/products/search"
ALGUMON_RANK_URL="https://www.algumon.com/deal/rank"

# Discovery/Tracking
DISCOVERY_KEYWORDS="노트북,SSD,세제,생수,이어폰"
DISCOVERY_LIMIT_PER_KEYWORD="40"
TRACK_BATCH_SIZE="180"
TRACK_LIMIT_PER_KEYWORD="50"
MAX_TRACKED_PRODUCTS="2000"
MIN_RECORD_INTERVAL_MIN="30"

# Scoring/Alert
ALERT_SCORE_MIN="68"
ALERT_COOLDOWN_HOURS="12"
MIN_DROP_PREV="0.12"
MIN_DROP_7D="0.18"
NEAR_LOW_BAND="1.03"

# DB/Retention
SQLITE_PATH="data/hotdeal.db"
HISTORY_RETENTION_DAYS="120"

# Preference Tuning (food / event)
PREFERRED_FOOD_KEYWORDS="식품,먹거리,라면,커피,생수,음료,쌀,과자,간식,닭가슴살,유제품,냉동,반찬,돈까스,아이스크림,만두,곰탕,오징어,펩시,제로,밥,컵밥,치즈"
PREFERRED_EVENT_KEYWORDS="쿠폰,적립,캐시,캐시백,페이백,이벤트,1+1,사은품,증정,할인전,프로모션,카드할인"
FOOD_BONUS_PER_HIT="2.4"
EVENT_BONUS_PER_HIT="2.2"
PREFERENCE_BONUS_CAP="12"
ALERT_PREFERENCE_RELAX="6"
MIN_DROP_30D_PREFERRED="0.08"
ALERT_MIN_REVIEWS="8"
MIN_RELIABILITY="0.18"
ALERT_MAX_PER_RUN="4"
TRACKER_DIGEST_ENABLED="true"
TRACKER_DIGEST_MIN_INTERVAL_MIN="60"
TRACKER_DIGEST_SCORE_MARGIN="45"

TRACKER_OBSERVED_SCAN_LIMIT="30"
